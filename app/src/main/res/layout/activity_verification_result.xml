<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/drawr">

    <!-- Top Loading Bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/loading_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/link_color"
        app:layout_constraintTop_toTopOf="parent"
        app:trackColor="?attr/cardStrokeColor"
        app:trackThickness="8dp"
        android:elevation="10dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Captured Claim -->
            <TextView
                android:id="@+id/label_claim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Captured Claim"
                android:textColor="?attr/textSecondary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_claim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@id/label_claim"
                tools:text="The text captured from your screen." />

            <!-- Verdict -->
            <TextView
                android:id="@+id/tv_verdict"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="?attr/textPrimary"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/tv_claim"
                tools:text="VERDICT" />

            <!-- Result Image -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_verdict"
                app:strokeColor="?attr/cardStrokeColor"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/iv_result_image"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    android:clickable="true"
                    android:focusable="true"
                    tools:src="@android:drawable/ic_menu_gallery" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Reality Score -->
            <TextView
                android:id="@+id/label_reality_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Reality Score"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_image" />

            <TextView
                android:id="@+id/tv_reality_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/label_reality_score"
                tools:text="0.8/1.0" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_reality_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="100"
                app:trackThickness="8dp"
                app:trackCornerRadius="4dp"
                app:trackColor="?attr/cardStrokeColor"
                app:layout_constraintTop_toBottomOf="@id/tv_reality_score" />

            <!-- Confidence -->
            <TextView
                android:id="@+id/label_confidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Confidence"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pb_reality_score" />

            <TextView
                android:id="@+id/tv_confidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/label_confidence"
                tools:text="95%" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/pb_confidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="100"
                app:trackThickness="8dp"
                app:trackCornerRadius="4dp"
                app:trackColor="?attr/cardStrokeColor"
                app:layout_constraintTop_toBottomOf="@id/tv_confidence" />

            <!-- Explanation -->
            <TextView
                android:id="@+id/label_explanation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Explanation"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/pb_confidence" />

            <TextView
                android:id="@+id/tv_explanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/label_explanation"
                tools:text="Detailed explanation goes here..." />

            <!-- Evidence -->
            <TextView
                android:id="@+id/label_evidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Supporting Evidence"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_explanation" />

            <LinearLayout
                android:id="@+id/ll_evidence_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/label_evidence" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_back_dashboard"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/btn_back_ripple"
                android:drawableStart="@android:drawable/ic_media_previous"
                android:drawablePadding="12dp"
                android:paddingHorizontal="24dp"
                android:text="Back to Dashboard"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/ll_evidence_container" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
