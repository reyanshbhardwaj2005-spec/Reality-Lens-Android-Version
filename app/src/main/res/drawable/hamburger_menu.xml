<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Adaptive Gradient Background -->
    <gradient
        android:angle="315"
        android:startColor="?attr/buttonGradientStart"
        android:centerColor="?attr/buttonGradientCenter"
        android:endColor="?attr/buttonGradientEnd" />

    <!-- Rounded Corners -->
    <corners android:radius="18dp" />

    <!-- Adaptive Border -->
    <stroke
        android:width="1.5dp"
        android:color="?attr/buttonStroke" />

    <!-- Padding -->
    <padding
        android:left="14dp"
        android:top="12dp"
        android:right="14dp"
        android:bottom="12dp" />

</shape>