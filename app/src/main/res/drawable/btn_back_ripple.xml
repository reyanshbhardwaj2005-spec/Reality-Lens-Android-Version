<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="?attr/buttonGradientStart"
                android:centerColor="?attr/buttonGradientCenter"
                android:endColor="?attr/buttonGradientEnd" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1.5dp"
                android:color="?attr/buttonStroke" />
        </shape>
    </item>
</ripple>