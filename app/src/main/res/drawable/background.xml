<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep Background Base -->
    <item>
        <shape android:shape="rectangle">

            <gradient
                android:angle="315"
                android:startColor="#02030A"
                android:centerColor="#0A0F1F"
                android:endColor="#000000" />

        </shape>
    </item>

    <!-- Purple Ambient Glow -->
    <item
        android:left="-120dp"
        android:top="-80dp"
        android:right="120dp"
        android:bottom="350dp">

        <shape android:shape="oval">

            <gradient
                android:type="radial"
                android:gradientRadius="500"
                android:startColor="#553B82F6"
                android:endColor="#00000000" />

        </shape>
    </item>

    <!-- Blue Glow -->
    <item
        android:left="180dp"
        android:top="450dp"
        android:right="-100dp"
        android:bottom="-150dp">

        <shape android:shape="oval">

            <gradient
                android:type="radial"
                android:gradientRadius="400"
                android:startColor="#4418FFFF"
                android:endColor="#00000000" />

        </shape>
    </item>

    <!-- Dark Overlay for Premium Look -->
    <item>
        <shape android:shape="rectangle">

            <gradient
                android:angle="90"
                android:startColor="#22000000"
                android:centerColor="#11000000"
                android:endColor="#33000000" />

        </shape>
    </item>

    <!-- Soft Bottom Shadow -->
    <item
        android:top="500dp">

        <shape android:shape="rectangle">

            <gradient
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#AA000000" />

        </shape>
    </item>

</layer-list>